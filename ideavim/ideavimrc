set hls ic is
set number
" ys, cs, ds, S
set surround
" gcc to comment out a line, gc to comment motion
set commentary

let mapleader = " "

" Search everywhere
map <leader>sf <Action>(SearchEverywhere)

" Refactorings
map <leader>oi <Action>(OptimizeImports)
map <leader>rn <Action>(RenameElement)
map <leader>rf <Action>(RenameFile)
map <leader>ri <Action>(Inline)
map <leader>rv <Action>(IntroduceVariable)
map <leader>rm <Action>(ExtractMethod)
map <leader>rr <Action>(Refactorings.QuickListPopupAction)
map <leader>rp <Action>(IntroduceParameter)
map <leader>im <Action>(ImplementMethods)
map <leader>om <Action>(OverrideMethods)

" Reformat Code
map <leader>rc <Action>(ReformatCode)
" Quickfix
map <leader>qf <Action>(ShowIntentionActions)

" GoTo
map gd <Action>(GotoDeclaration)
map gr <Action>(FindUsages)
map gi <Action>(GotoImplementation)
map gs <Action>(ActivateStructureToolWindow)
map <leader>gi <Action>(GotoImplementation)
map <leader>gs <Action>(ActivateStructureToolWindow)
map <leader>sp <Action>(ParameterInfo)
map <leader>si <Action>(Scala.ShowImplicitArguments)
map <leader>sd <Action>(QuickImplementations)

map <C-h> <Action>(QuickDocumentation)

" Types
""map K <Action>(Scala.TypeInfo)
""vmap K <Action>(Scala.TypeInfo)

" Search
map <leader>fs <Action>(GotoSymbol)
map <leader>ff <Action>(GotoFile)
map <leader>fc <Action>(GotoClass)
map <leader>fa <Action>(GotoAction)
map <leader>fg <Action>(FindInPath)
map <leader>fr <Action>(ReplaceInPath)

" Test and Run
map <leader>gt <Action>(GotoTest)
map <leader>tn <Action>(RunClass)
map <leader>tl <Action>(Rerun)
map <leader>tf <Action>(RerunFailedTests)
map <leader>tc <Action>(RunContextGroup)

" Undo
map <leader>uh <Action>(LocalHistory.ShowHistory)

" Jumping
" built-in navigation to navigated items works better
map <c-o> <Action>(Back)
map <c-i> <Action>(Forward)

" Navigation
map ]c <Action>(GotoNextError)
map [c <Action>(GotoPreviousError)
map ]d <Action>(GotoNextError)
map [d <Action>(GotoPreviousError)
map ]h <Action>(VcsShowNextChangeMarker)
map [h <Action>(VcsShowPrevChangeMarker)

" copy / paste
noremap <leader>y "+y
noremap <leader>Y "+Y
noremap <leader>p "+p
noremap <leader>P "+P

" delete without yanking
map <leader>d "_d
vnoremap <leader>d "_d

" replace currently selected text with default register
" without yanking it
vnoremap <leader>p "_dP"

sethandler <C-C> n-v:ide i:vim
sethandler <C-N> n-v:ide i:vim
sethandler <C-P> ide

map <leader>z <Action>(ToggleDistractionFreeMode)
